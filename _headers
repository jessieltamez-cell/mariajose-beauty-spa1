# ============================================================
#  Headers de seguridad — Maria José Beauty & Spa
#  Aplican a TODAS las rutas (/*) excepto donde se sobreescribe
# ============================================================

/*
  # Previene clickjacking — nadie puede embeber el sitio en un iframe
  X-Frame-Options: DENY

  # Previene MIME sniffing
  X-Content-Type-Options: nosniff

  # Controla referrer al salir del sitio
  Referrer-Policy: strict-origin-when-cross-origin

  # HTTPS estricto — 1 año, incluye subdominios
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Deshabilita APIs del navegador que no se usan
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()

  # Content Security Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://w.behold.so 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://w.behold.so 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; media-src https://*.cdninstagram.com https://*.behold.so; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.behold.so https://graph.instagram.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';

  # Cross-Origin policies
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Cross-Origin-Embedder-Policy: unsafe-none

# ── admin.html: más restrictivo, sin indexación ──────────────
/admin.html
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex, nofollow, noarchive
  Referrer-Policy: no-referrer
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.jsdelivr.net 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self';
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Cache-Control: no-store, no-cache, must-revalidate
